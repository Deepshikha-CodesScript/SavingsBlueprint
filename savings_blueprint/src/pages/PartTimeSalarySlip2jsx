    const validYears = growthYears.filter(
      (item) => Number(item.income) > 0
    );

    if (validYears.length < 2) return 0;

    const firstIncome = Number(
      validYears[0].income
    );

    const lastIncome = Number(
      validYears[validYears.length - 1]
        .income
    );

    const years = validYears.length - 1;

    return (
      ((lastIncome - firstIncome) /
        firstIncome) *
      (100 / years)
    ).toFixed(2);
