              const mandatory =
                mandatoryDeductions.reduce(
                  (s, item) =>
                    s +
                    Number(
                      month.mandatory?.[
                        item
                      ] || 0
                    ),
                  0
                );

              const personal =
                personalDeductions.reduce(
                  (s, item) =>
                    s +
                    Number(
                      month.personal?.[
                        item
                      ] || 0
                    ),
                  0
                );

              const other =
                otherIncomeHeads.reduce(
                  (s, item) =>
                    s +
                    Number(
                      month.otherIncome?.[
                        item
                      ] || 0
                    ),
                  0
                );

              return (
                sum +
                (
                  earning -
                  mandatory -
                  personal +
                  other
                )
              );

            },
            0
          ).toFixed(2)
        }

      </strong>

    </td>

  </tr>

</tbody>

          </table>

        </div>

      </div>

      {/* GROWTH CALCULATOR */}

      <div className="growth-calculator">

        <h2>
          Income Growth Rate Calculator
        </h2>

        <table>

          <thead>
            <tr>
              <th>Year</th>
              <th>Average Income</th>
            </tr>
          </thead>

          <tbody>

            {growthYears.map(
              (item, index) => (
                <tr key={index}>

                  <td>
                    <input
                      type="text"
                      value={item.year}
                      onChange={(e) => {
                        const updated = [
                          ...growthYears,
                        ];

                        updated[index].year =
                          e.target.value;

                        setGrowthYears(
                          updated
                        );
                      }}
                    />
                  </td>

                  <td>
                    <input
                      type="number"
                      value={item.income}
                      onChange={(e) => {
                        const updated = [
                          ...growthYears,
                        ];

                        updated[index].income =
                          e.target.value;

                        setGrowthYears(
                          updated
                        );
                      }}
                    />
                  </td>

                </tr>
              )
            )}

          </tbody>

        </table>

        <div className="growth-result">

          Annual Growth Rate :

          <strong>
            {calculateGrowthRate()}%
          </strong>

        </div>

      </div>

      {/* FOOTER */}

      <div className="bottom-actions">

        <button onClick={handleSave}>
          Save
        </button>

        <button onClick={handleEdit}>
          Edit
        </button>

        <button onClick={handleUpdate}>
          Update
        </button>

        <button onClick={handleDelete}>
          Delete
        </button>

      </div>

    </div>
  );
};

export default PartTimeSalarySlip;

